{
  "name": "hookwave-sdk",
  "version": "0.1.0",
  "description": "Official Node.js SDK for Hookwave — emit events into a Hookwave source. Batched, retried, fire-and-forget.",
  "keywords": [
    "hookwave",
    "webhook",
    "webhooks",
    "events",
    "sdk",
    "client"
  ],
  "license": "MIT",
  "author": "Hookwave",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hookwave/sdk-node.git"
  },
  "homepage": "https://docs.hookwave.dev",
  "bugs": "https://github.com/hookwave/sdk-node/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "example": "concurrently -k -s first -n mock,demo -c gray,cyan \"tsx example/mock-server.ts\" \"sleep 1 && tsx example/index.ts\"",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
